{
  "name": "bubblyclouds-auth",
  "version": "0.1.0",
  "description": "Auth Service for Bubbly Clouds",
  "scripts": {
    "start": "npm --prefix ./deploy run cdk:synth && sam local start-api -t ./deploy/cdk.out/AuthStack.template.json",
    "start:ssl": "npx local-ssl-proxy --config local-ssl-proxy.json",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.integration.config.cjs --runInBand",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "check:circular": "npx --yes madge --circular --extensions ts src/",
    "prepare": "husky"
  },
  "author": "James Acres",
  "type": "module",
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/ejs": "^3.1.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/koa__router": "^12.0.5",
    "@types/koa-mount": "^4.0.5",
    "@types/node": "^26.0.0",
    "@types/oidc-provider": "^9.5.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-prettier": "^5.5.6",
    "exponential-backoff": "^3.1.3",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.2.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jose": "^6.2.3",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1075.0",
    "@aws-sdk/client-sesv2": "^3.1075.0",
    "@aws-sdk/lib-dynamodb": "^3.1075.0",
    "@koa/router": "^15.6.0",
    "ejs": "^6.0.1",
    "jsonwebtoken": "^9.0.3",
    "koa": "^3.2.1",
    "koa-body": "^8.0.0",
    "koa-mount": "^4.2.0",
    "nanoid": "^5.1.15",
    "oidc-provider": "^9.8.5",
    "openid-client": "^6.8.4",
    "serverless-http": "^4.0.0"
  }
}
